# 主线配置：以后优先改这里，不再手写很长的命令。
# 说明：短脚本会读取本文件；历史长命名文件仍保留，用于复现实验日志。

export REGRET_ROOT="${REGRET_ROOT:-/root/autodl-tmp/0408Yambda/Regret}"

# 当前正式主线名。对外汇报时叫 main_v1，不再暴露 rqkm/srun/brev 这类缩写。
export MAIN_ID="${MAIN_ID:-main_v1}"

# 原始数据和映射。
export MULTI_EVENT_PARQUET="${MULTI_EVENT_PARQUET:-/root/autodl-tmp/0330Yambda/data/sequential-50m/multi_event.parquet}"
export ORIG2DENSE_NPY="${ORIG2DENSE_NPY:-${REGRET_ROOT}/artifacts/mappings/raw_rqkmeans/orig2dense_item_id.npy}"
export DENSE_ITEM_FEATURES_NPY="${DENSE_ITEM_FEATURES_NPY:-${REGRET_ROOT}/artifacts/mappings/raw_rqkmeans/dense_item_features.npy}"
export DENSE_ITEM2SID_NPY="${DENSE_ITEM2SID_NPY:-${REGRET_ROOT}/artifacts/mappings/raw_rqkmeans/dense_item2sid.npy}"

# 当前主线产物的短路径。artifacts/current 下面是软链接，指向已验证的真实产物。
export TRANSITION_ROOT="${TRANSITION_ROOT:-${REGRET_ROOT}/artifacts/current/data}"
export SIM_OUT_DIR="${SIM_OUT_DIR:-${REGRET_ROOT}/artifacts/current/simulator}"
export SIMULATOR_CHECKPOINT="${SIMULATOR_CHECKPOINT:-${SIM_OUT_DIR}/regret_user_response.pt}"
export POLICY_ACTOR="${POLICY_ACTOR:-${REGRET_ROOT}/artifacts/current/policy_actor}"
export POLICY_CRITIC="${POLICY_CRITIC:-${REGRET_ROOT}/artifacts/current/policy_critic}"
export POLICY_META="${POLICY_META:-${REGRET_ROOT}/artifacts/current/policy_meta.json}"

# 如果重新切分/重新训练，默认写到短名字 main_v1_*；训练确认后再按需要更新 artifacts/current。
export DATA_OUT_ROOT="${DATA_OUT_ROOT:-${REGRET_ROOT}/artifacts/transitions/main_v1_data}"
export SIM_TRAIN_OUT_DIR="${SIM_TRAIN_OUT_DIR:-${REGRET_ROOT}/artifacts/user_response/main_v1_simulator}"
export ACTOR_INIT_CHECKPOINT="${ACTOR_INIT_CHECKPOINT:-${REGRET_ROOT}/artifacts/models/regret_sid_session_run_v2_actor}"
export POLICY_SAVE_PREFIX="${POLICY_SAVE_PREFIX:-${REGRET_ROOT}/artifacts/models/policy_hsac_main}"
export POLICY_SAVE_META="${POLICY_SAVE_META:-${POLICY_SAVE_PREFIX}.meta.json}"

# 数据切分：1 小时断 session；单 session 最长 6 小时；连续同 item 最多聚合 100 个原始事件。
export HISTORY_LEN="${HISTORY_LEN:-50}"
export SESSION_GAP_SECONDS="${SESSION_GAP_SECONDS:-3600}"
export MAX_SESSION_SPAN_SECONDS="${MAX_SESSION_SPAN_SECONDS:-21600}"
export MAX_RUN_EVENTS="${MAX_RUN_EVENTS:-100}"
export REPLAY_EVAL_STEPS="${REPLAY_EVAL_STEPS:-50}"
export TIMESTAMP_UNIT_SECONDS="${TIMESTAMP_UNIT_SECONDS:-5.0}"
export ANCHOR_POLICY="${ANCHOR_POLICY:-first_visible}"
export SHARD_ROWS="${SHARD_ROWS:-50000}"
export MAX_USERS="${MAX_USERS:-0}"
export REWARD_VERSION="${REWARD_VERSION:-v2}"

# 失败记忆池：low_play / dislike / unlike 都进入 RAPI 记忆池。
export PRECOMPUTE_REGRET_MEMORY="${PRECOMPUTE_REGRET_MEMORY:-1}"
export REGRET_MEMORY_SIZE="${REGRET_MEMORY_SIZE:-20}"
export REGRET_MEMORY_GAMMA="${REGRET_MEMORY_GAMMA:-0.9}"
export REGRET_MEMORY_SCOPE="${REGRET_MEMORY_SCOPE:-all_failed}"

# simulator：只作为评估与交互反馈近似，不再追求完美拟合所有细粒度动作。
export SIM_MAX_TRAIN_ROWS="${SIM_MAX_TRAIN_ROWS:-1000000}"
export SIM_MAX_VAL_ROWS="${SIM_MAX_VAL_ROWS:-10000}"
export SIM_MAX_TEST_ROWS="${SIM_MAX_TEST_ROWS:-10000}"
export SIM_EPOCHS="${SIM_EPOCHS:-3}"
export SIM_BATCH_SIZE="${SIM_BATCH_SIZE:-256}"
export SIM_LR="${SIM_LR:-0.0001}"

# 策略训练：HSAC + simulator rollout + RRCA 有效 reward 修正。
export HSAC_EPISODES="${HSAC_EPISODES:-100000}"
export HSAC_EPOCHS="${HSAC_EPOCHS:-1}"
export HSAC_BATCH_SIZE="${HSAC_BATCH_SIZE:-16}"
export HSAC_READ_BATCH_SIZE="${HSAC_READ_BATCH_SIZE:-512}"
export HSAC_MAX_STEPS="${HSAC_MAX_STEPS:-10}"
export HSAC_DECODE_TOP_K="${HSAC_DECODE_TOP_K:-4}"
export HSAC_GAMMA="${HSAC_GAMMA:-0.9}"
export HSAC_ACTOR_LR="${HSAC_ACTOR_LR:-0.00001}"
export HSAC_CRITIC_LR="${HSAC_CRITIC_LR:-0.0003}"
export MEMORY_SIGNAL_SCOPE="${MEMORY_SIGNAL_SCOPE:-all_failed}"
export HSAC_SARA_ETA="${HSAC_SARA_ETA:-0.10}"

# 评估：默认 eta=0.10，全量主线用 1000 条 rollout episode。
export ROLLOUT_EPISODES="${ROLLOUT_EPISODES:-1000}"
export ROLLOUT_MAX_STEPS="${ROLLOUT_MAX_STEPS:-20}"
export ROLLOUT_DECODE_TOP_K="${ROLLOUT_DECODE_TOP_K:-8}"
export SARA_ETA="${SARA_ETA:-0.10}"
export ETA_LIST="${ETA_LIST:-0.05 0.10 0.20 0.30 0.50}"
